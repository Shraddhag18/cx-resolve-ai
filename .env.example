# Optional overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
FAISS_INDEX_PATH=data/faiss_index
DOCS_DIR=data/sample_docs
RETRIEVER_TOP_K=5
MAX_TOKENS=1024
